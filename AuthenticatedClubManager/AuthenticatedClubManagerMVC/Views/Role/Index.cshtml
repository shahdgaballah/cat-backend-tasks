@model IEnumerable<RolesViewModel>


<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Role List</h2>
        </div>
        <div class="col-6 text-end">
            @* //creating url which will be redirected when clicking on create button=> creating Create() method inside the controller *@
            <a asp-controller="Role" asp-action="Create"
               class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> &nbsp; Create new Role
            </a>
        </div>
    </div>

</div>
<table class="table table-bordered table-striped" style="width:100%">
    <thead>
        <tr>
            <th>Name</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td width="50%">@item.Name</td>
                
                <td>
                    <div class="w-75 btn-group" role="group">
                        <a asp-controller="Role" asp-action="Update" asp-route-id="@item.Id"
                           class="btn btn-primary mx-2"> <i class="bi bi-pencil-square"></i> Edit</a>
                    </div>
                </td>
                <td>
                    <div class="w-75 btn-group" role="group">
                        <a asp-controller="Role" asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-primary mx-2 bg-danger"> <i class="bi bi-pencil-square"></i>Delete</a>
                    </div>
                </td>
                <td>
                    <div class="w-75 btn-group" role="group">
                        <a asp-controller="Role" asp-action="ManageUserRole" asp-route-id="@item.Id"
                           class="btn btn-primary mx-2"> <i class="bi bi-pencil-square"></i> Manage user roles</a>
                    </div>
                    
                </td>


            </tr>
        }
    </tbody>
</table>
