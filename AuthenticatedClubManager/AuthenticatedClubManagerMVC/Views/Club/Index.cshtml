@model IEnumerable<Club>
@{
    ViewData["Title"] = "Index";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Club List</h2>
        </div>

        <div class="col-6 text-end">
            @* //creating url which will be redirected when clicking on create button=> creating Create() method inside the controller *@
            <a asp-controller="Club" asp-action="Create"
               class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> &nbsp; Create new Club
            </a>
        </div>
    </div>

    <br /><br />

    <table class="table table-bordered table-striped" style="width:100%">
        <thead>
            <tr>
                <th>Club Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Image</th>
                @* <th>Category</th> *@
                
                


            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td width="50%">@item.Name</td>
                    <td width="50%">@item.Description</td>
                    <td width="50%">@item.Price</td>
                    <td width="50%">
                        <img src="@item.ImagePath" alt="An image" height="50" width="50" />
                    </td>
                    @* <td width="50%">@item.CategoryId</td> *@
                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="Club" asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-primary mx-2"> <i class="bi bi-pencil-square"></i> Edit</a>
                        </div>
                    </td>
                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="Club" asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-primary mx-2 bg-danger"> <i class="bi bi-pencil-square"></i>Delete</a>
                        </div>
                    </td>


                </tr>
            }
        </tbody>
    </table>
</div>
